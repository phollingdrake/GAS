  for (i = 0; (i < bookingsOnTempEventDate.length) ; i++) {
    
    
   // if (bookingsOnTempEventDate[i].getTitle().search('?') == -1) {  // make sure to filter out held bookings  // also filter out cancelled bookings.
    

function scanAndLabelJobRequests(resources) {
  // Label emails from specific senders with 'labelPastBookings' if the system thinks they're
  // in the past, and checks for calendar clashes, while excluding messages I've replied to.

  var labelInbox = resources.flunkieLabels.labelInbox;
  var labelFlunkie = resources.flunkieLabels.labelFlunkie; // to be used for system messages
  var labelPastBookings = resources.flunkieLabels.labelPastBookings;
  var labelClashes = resources.flunkieLabels.labelClashes;
  var unreadCount = labelInbox.getUnreadCount(); //if only used in the next line, just fold the count in there and don't declare a variable
  Logger.log('the number of unread emails with the label [flunkie]/Inbox is ' + unreadCount);
  
  var flunkieInboxThreads = labelInbox.getThreads();
  Logger.log('count of [flunkie]/Inbox threads: ' + flunkieInboxThreads.length);

  var filteredThreads = alteredFilterFunction(flunkieInboxThreads.slice(0, MAX_THREADS)); // passes relevant threads, capped(/sliced) to the global max variable.
  Logger.log('count of filtered down threads: ' + filteredThreads.length);
  

  var i;
  var messageSubject;
  var tempEventsCal = resources.tempEventsCal;
  var tempEvent;
  var tempEventEnd;
  var now = new Date();

  for (i = 0; i < filteredThreads.length; i++) {
    tempEvent = null;
    messageSubject = '(subject not retrieved)';
    try {
      messageSubject = filteredThreads[i].getFirstMessageSubject();
      tempEvent = tempEventsCal.createEventFromDescription(messageSubject);
      tempEventEnd = tempEvent.getEndTime();
      if (now > tempEventEnd) {
        filteredThreads[i].removeLabel(labelInbox).addLabel(labelPastBookings);
      } else if (doesEventClash(tempEvent)) {
        filteredThreads[i].removeLabel(labelInbox).addLabel(labelClashes);
      }
      Logger.log('message check count = ' + i);
    } catch (e) {
      Logger.log('Error on thread ' + i + ' — subject: "' + messageSubject + '" — ' + e.message);
    } finally {
      if (tempEvent !== null) { tempEvent.deleteEvent(); }
    }
  }


}


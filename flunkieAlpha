}

function getOrCreateEmailLogFile(props, systemFolder) {
  var file = tryGetFileById(props.getProperty('EMAIL_LOG_FILE_ID'));
  if (file) return file;

  var existing = systemFolder.getFilesByName('emailLog.json');
  if (existing.hasNext()) {
    file = existing.next();
  } else {
    file = systemFolder.createFile('emailLog.json', JSON.stringify({}), MimeType.PLAIN_TEXT);
  }

  props.setProperty('EMAIL_LOG_FILE_ID', file.getId());
  return file;
}


function getOrCreateFlunkieFolder(props) {
  var folder = tryGetFolderById(props.getProperty('FOLDER_ID'));
  if (folder) return folder;

  var existing = DriveApp.getFoldersByName('flunkieApp');
  if (existing.hasNext()) {
    folder = existing.next();
  } else {
    folder = DriveApp.createFolder('flunkieApp');
  }

  props.setProperty('FOLDER_ID', folder.getId());
  return folder;
}

function getOrCreateSystemSubfolder(props, parentFolder) {
  var folder = tryGetFolderById(props.getProperty('SYSTEM_FOLDER_ID'));
  if (folder) return folder;

  var existing = parentFolder.getFoldersByName('flunkie System (do not edit)');
  if (existing.hasNext()) {
    folder = existing.next();
  } else {
    folder = parentFolder.createFolder('flunkie System (do not edit)');
  }

  props.setProperty('SYSTEM_FOLDER_ID', folder.getId());
  return folder;
}

function getOrCreateFlunkieSheet(props, parentFolder) {
  var sheetId = props.getProperty('SHEET_ID');
  var file = tryGetFileById(sheetId);
  if (file) return SpreadsheetApp.openById(sheetId);

  var existing = parentFolder.getFilesByName('flunkie Dashboard');
  var spreadsheet;
  if (existing.hasNext()) {
    spreadsheet = SpreadsheetApp.open(existing.next());
  } else {
    // SpreadsheetApp.create() always creates in root — must move it after
    spreadsheet = SpreadsheetApp.create('flunkie Dashboard');
    var createdFile = DriveApp.getFileById(spreadsheet.getId());
    createdFile.moveTo(parentFolder);
  }

  props.setProperty('SHEET_ID', spreadsheet.getId());
  return spreadsheet;
}

